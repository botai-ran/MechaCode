{
  "name": "@mecha/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mecha-chat": "./dist/cli/index.js",
    "mecha-runtime-sidecar": "./dist/sidecar/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "chat": "tsx src/cli/index.ts",
    "sidecar": "tsx src/sidecar/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @mecha/protocol build && pnpm --filter @mecha/shared build && pnpm --filter @mecha/agent-tools build && pnpm run build && node --test dist/runtime/agent-run.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@mecha/agent-tools": "workspace:*",
    "@mecha/protocol": "workspace:*",
    "@mecha/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
  }
}
