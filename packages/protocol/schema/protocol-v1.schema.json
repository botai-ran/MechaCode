{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mecha.protocol.v1",
  "title": "Mecha Protocol v1 Envelope",
  "type": "object",
  "additionalProperties": true,
  "required": ["protocolVersion", "runId", "seq", "type", "payload"],
  "properties": {
    "protocolVersion": {
      "type": "string",
      "pattern": "^1\\.\\d+\\.\\d+$"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "seq": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "type": {
      "type": "string",
      "enum": [
        "run_start",
        "security_snapshot",
        "model_request_start",
        "message_start",
        "text_delta",
        "message_done",
        "tool_call_start",
        "tool_approval_request",
        "tool_approval_resolved",
        "tool_call_done",
        "tool_result",
        "error",
        "run_done"
      ]
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "runtimeCapabilitySnapshot": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mode",
        "policyVersion",
        "read",
        "write",
        "command",
        "network",
        "sensitiveFileProtection"
      ],
      "properties": {
        "mode": {
          "const": "default_deny"
        },
        "policyVersion": {
          "type": "string",
          "minLength": 1
        },
        "read": {
          "type": "boolean"
        },
        "write": {
          "type": "boolean"
        },
        "command": {
          "type": "boolean"
        },
        "network": {
          "type": "boolean"
        },
        "sensitiveFileProtection": {
          "type": "boolean"
        },
        "frozenAt": {
          "type": "string"
        }
      }
    },
    "protocolErrorEnvelope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code", "message", "retryable", "source"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        },
        "source": {
          "type": "string",
          "enum": ["desktop", "tauri", "runtime", "tools", "provider", "protocol"]
        },
        "details": {
          "type": "object"
        }
      }
    },
    "runTerminalStatus": {
      "type": "string",
      "enum": ["completed", "failed", "cancelled", "interrupted"]
    }
  },
  "x-mecha": {
    "id": "mecha.protocol.v1",
    "version": "1.0.0",
    "majorVersion": 1,
    "requiredEnvelopeFields": ["protocolVersion", "runId", "seq", "type", "payload"],
    "eventTypes": [
      "run_start",
      "security_snapshot",
      "model_request_start",
      "message_start",
      "text_delta",
      "message_done",
      "tool_call_start",
      "tool_approval_request",
      "tool_approval_resolved",
      "tool_call_done",
      "tool_result",
      "error",
      "run_done"
    ],
    "compatibility": {
      "sameMajorVersion": "backward_compatible",
      "unknownEvent": "ignore",
      "incompatibleMajorVersion": "fail_handshake"
    }
  }
}
